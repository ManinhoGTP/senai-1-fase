programa {
  funcao inicio() {

      //Variáveis
     inteiro numero

     //Input
     escreva("Digite um número e descubra se ele é par ou impar: ")
     leia(numero)

     //Processar informações / Output
     se(numero % 2 == 0){
      escreva("Esse número é par!!")
     }senao{
      escreva("Esse número é impar!!")
     }

    }
  }